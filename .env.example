# Example environment variables file.
# Copy it to app/instance/.env (or .env in the repo root) and fill it in.
#   cp .env.example app/instance/.env
# The app reads app/instance/.env first, then .env in the repo root.

# --- Application settings (read in config.py) ---

# Key used to sign sessions. IN PRODUCTION set a long, random secret.
SECRET_KEY=change-me

# Database address. Defaults to a local SQLite file at app/instance/app.db.
DATABASE_URL=sqlite:///app/instance/app.db

# Whether new accounts can register (true/false).
REGISTRATION_ENABLED=true

# How many days to keep the "remember me" session.
REMEMBER_COOKIE_DAYS=30

# Version shown in the app. Empty = read from the VERSION file.
APP_VERSION=

# Pre-fill the login form (handy on a self-hosted server).
# Leave empty if you don't want to suggest login credentials.
DEFAULT_LOGIN_EMAIL=
DEFAULT_LOGIN_PASSWORD=

# Timezone used to determine "day" boundaries in time tracking.
CALENDAR_TIMEZONE=Europe/Warsaw

# Read, but CURRENTLY UNUSED by the app (reserved for a future AI feature).
OPENAI_API_KEY=

# Set to 1 to disable the automatic database update at app startup.
# In Docker it is set to 1 (migrations run via docker-entrypoint.sh). Leave empty locally.
# SKIP_DB_BOOTSTRAP=1

# --- Settings used only when running in Docker ---

# Host port mapped to the container's port 8000.
APP_PORT=8000

# Number of Gunicorn worker processes and its timeout.
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
